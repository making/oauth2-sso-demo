<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign In</title>
    <link rel="stylesheet" href="/css/style.css">
    {{#_csrf}}
    <meta name="csrf-header" content="{{_csrf.headerName}}">
    <meta name="csrf-token" content="{{_csrf.token}}">
    {{/_csrf}}
    <script src="/js/script.js"></script>
</head>
<body>

<div class="container">
    <h1 class="title">Sign in</h1>
    <p class="subtitle">Use your organization credentials</p>

    {{#springMacroRequestContext.request.parameterMap.signup}}
        <div class="success-banner" style="display:flex;align-items:center;gap:0.5rem;background:rgba(74,222,128,0.1);border:1px solid rgba(74,222,128,0.25);border-radius:8px;padding:0.75rem 1rem;margin-bottom:2rem;">
            <span style="font-size:0.8125rem;color:#86efac;">Account created successfully. Please sign in.</span>
        </div>
    {{/springMacroRequestContext.request.parameterMap.signup}}

    {{#springMacroRequestContext.request.parameterMap.error}}
        <div class="error-banner">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                 stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <line x1="15" y1="9" x2="9" y2="15"/>
                <line x1="9" y1="9" x2="15" y2="15"/>
            </svg>
            <span>{{SPRING_SECURITY_LAST_EXCEPTION}}</span>
        </div>
    {{/springMacroRequestContext.request.parameterMap.error}}

    <form action="/login" method="post" class="form">
        <div class="field">
            <label for="username">Username</label>
            <input
                    type="text"
                    id="username"
                    name="username"
                    autocomplete="username"
                    placeholder="you@example.com"
                    required
            >
        </div>

        <div class="field">
            <label for="password">Password</label>
            <input
                    type="password"
                    id="password"
                    name="password"
                    autocomplete="current-password"
                    required
            >
        </div>

        {{#_csrf}}
            <input type="hidden" name="_csrf" value="{{_csrf.token}}"/>
        {{/_csrf}}

        <button type="submit" class="btn">Sign in</button>
    </form>

    <button type="button" id="passkey-signin" class="btn btn-secondary" style="margin-top: 1rem;">Sign in with a passkey</button>

    <p class="consent-footer">Don't have an account? <a href="/signup" style="color: #d4e157;">Sign up</a></p>
</div>

</body>
</html>
