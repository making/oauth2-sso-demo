<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="container">
    <h1 class="title">Welcome</h1>
    <p class="subtitle">You are signed in</p>

    {{#springMacroRequestContext.request.parameterMap.passwordChanged}}
    <div class="success-banner" style="display:flex;align-items:center;gap:0.5rem;background:rgba(74,222,128,0.1);border:1px solid rgba(74,222,128,0.25);border-radius:8px;padding:0.75rem 1rem;margin-bottom:2rem;">
        <span style="font-size:0.8125rem;color:#86efac;">Password has been changed successfully.</span>
    </div>
    {{/springMacroRequestContext.request.parameterMap.passwordChanged}}

    <div style="margin-bottom: 3rem;">
        <p class="user-info">Username</p>
        <p class="username">{{username}}</p>
    </div>

    <p class="user-info" style="margin-bottom: 1.5rem;">Applications</p>
    <div class="app-list">
        {{#clients}}
        <a href="{{url}}" target="_blank" rel="noopener noreferrer" class="app-card">
            <span class="app-name">{{clientName}}</span>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </a>
        {{/clients}}
    </div>
    {{^clients}}
    <p class="no-clients">No applications registered.</p>
    {{/clients}}

    <a href="/change-password" class="btn btn-secondary" style="margin-top: 3rem;">Change Password</a>
    <a href="/passkeys" class="btn btn-secondary" style="margin-top: 0.75rem;">Manage Passkeys</a>
    <a href="/logout" class="btn" style="margin-top: 0.75rem;">Sign Out</a>
</div>

</body>
</html>
